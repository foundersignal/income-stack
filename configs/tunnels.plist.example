<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.foundersignal.tunnels</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/ssh</string>
        <string>-N</string>
        <string>-p</string>
        <string>2222</string>
        <string>-o</string>
        <string>ServerAliveInterval=30</string>
        <string>-o</string>
        <string>ServerAliveCountMax=3</string>
        <string>-o</string>
        <string>ExitOnForwardFailure=yes</string>
        <string>-L</string>
        <string>3333:127.0.0.1:3333</string>
        <string>-L</string>
        <string>3847:127.0.0.1:3847</string>
        <string>-L</string>
        <string>4000:127.0.0.1:4000</string>
        <string>root@SERVER_IP</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardErrorPath</key>
    <string>/tmp/foundersignal-tunnels.err</string>
    <key>StandardOutPath</key>
    <string>/tmp/foundersignal-tunnels.out</string>
</dict>
</plist>
